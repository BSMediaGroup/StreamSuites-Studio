# Public browser configuration only. Do not place secrets, tokens, account IDs,
# Realtime credentials, room tokens, or provider keys in VITE_* variables.

# Runtime/Auth API origin used by a future same-account session bridge.
# Example for local integration work: http://127.0.0.1:18087
VITE_RUNTIME_API_BASE_URL=

# Optional public URL that serves the runtime-owned version.json export.
# Leave blank until Studio deployment and CORS/publication behavior are confirmed.
VITE_RUNTIME_VERSION_URL=
