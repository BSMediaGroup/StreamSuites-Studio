# Public browser configuration only. Do not place secrets, tokens, account IDs,
# Realtime credentials, room tokens, or provider keys in VITE_* variables.

# Runtime/Auth API origin used by the shared session and Studio access bridge.
# The client has this established production fallback; set it explicitly in Pages
# when deployment configuration should remain visible. Local fallback: http://127.0.0.1:18087
VITE_RUNTIME_API_BASE_URL=https://api.streamsuites.app

# Turnstile follows the existing StreamSuites contract: Studio fetches the
# public site key from VITE_RUNTIME_API_BASE_URL/auth/turnstile/config. There is
# intentionally no VITE_* Turnstile key. Configure CLOUDFLARE_TURNSTILE_SITEKEY
# (public value) and CLOUDFLARE_TURNSTILE_SECRET (server secret) on Runtime/Auth,
# never in this Pages client. Local login expects the local Runtime/Auth origin
# above to expose the same config endpoint; production Pages only needs the
# Runtime/Auth base URL to reach that runtime-owned configuration.

# Optional public URL that serves the runtime-owned version.json export.
VITE_RUNTIME_VERSION_URL=https://admin.streamsuites.app/runtime/exports/version.json
